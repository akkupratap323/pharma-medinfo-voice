# MultiPersona AI Voice Agents — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ===========================================
# Required API Keys
# ===========================================

# Deepgram — Speech-to-Text (Nova-3)
# Get your key: https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Groq — LLM inference (llama-3.1-8b-instant, free tier available)
# Get your key: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Cartesia — Text-to-Speech (Sonic-3)
# Get your key: https://play.cartesia.ai/
# Get voice IDs: https://play.cartesia.ai/voices
CARTESIA_API_KEY=your_cartesia_api_key_here
CARTESIA_VOICE_ID=your_default_voice_id_here

# Google AI — Gemini for text sentiment (emotion detection)
# Get your key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ===========================================
# Optional API Keys
# ===========================================

# Tally.so — Appointment booking form submissions
# Get your key: https://tally.so/help/api
TALLY_API_KEY=your_tally_api_key_here

# Picovoice Koala — Noise suppression (optional, WebRTC used as free fallback)
# Get your key: https://console.picovoice.ai/
KOALA_ACCESS_KEY=your_koala_access_key_here

# ai-coustics — Speech enhancement (currently disabled, SDK mismatch)
AIC_LICENSE_KEY=your_aic_license_key_here

# ===========================================
# Server Configuration
# ===========================================

FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=7860

WEBSOCKET_HOST=0.0.0.0
WEBSOCKET_PORT=8765

SESSION_TIMEOUT=180
LOG_LEVEL=INFO

# ===========================================
# Production / HTTPS Deployment
# ===========================================

# Your domain (for Caddy auto-HTTPS)
# Examples: yourdomain.com, 1.2.3.4.nip.io
DOMAIN=localhost

# Public URL for WebSocket connections
PUBLIC_URL=https://yourdomain.com

# ===========================================
# ngrok (for local public access / testing)
# ===========================================

# Get authtoken: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# Optional: custom ngrok domain (paid plan)
# NGROK_DOMAIN=your-domain.ngrok-free.app
