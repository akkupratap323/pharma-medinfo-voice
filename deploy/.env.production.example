# Synthio Voice AI — production .env for the EC2 box.
# Copy to /opt/synthio/.env, fill in the real keys, then `chmod 600 .env`.
#
# ⚠️  Do NOT put AWS credentials here. This app never calls AWS at runtime;
#     AWS keys belong only in ~/.aws/credentials on your laptop.

# --- Third-party APIs (all cloud) ---
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=          # used by LightRAG (extraction/embeddings) + A2UI template selection

# --- Local LightRAG (two servers on this box) ---
# LIGHTRAG_API_KEY is a token YOU choose; bootstrap.sh generates one if blank.
LIGHTRAG_API_KEY=
LIGHTRAG_BASE_URL=http://localhost:9621
LIGHTRAG_BASE_URL_HCP=http://localhost:9621
LIGHTRAG_BASE_URL_PATIENT=http://localhost:9622

# --- Critical: let httpx reach localhost LightRAG directly (no proxy) ---
NO_PROXY=localhost,127.0.0.1
no_proxy=localhost,127.0.0.1

# --- Server ---
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=7860
WEBSOCKET_SERVER=fast_api
MAX_SESSIONS=6           # concurrent voice calls — 2GB box holds ~6
LOG_LEVEL=INFO
